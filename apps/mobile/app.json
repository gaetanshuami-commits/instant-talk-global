{
  "expo": {
    "name": "Instant Talk",
    "slug": "instant-talk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "instanttalk",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#04070f"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.instanttalk.app",
      "buildNumber": "1",
      "requireFullScreen": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Instant Talk uses the camera for video in multilingual meetings.",
        "NSMicrophoneUsageDescription": "Instant Talk uses the microphone for real-time voice translation and meeting audio.",
        "NSPhotoLibraryUsageDescription": "Instant Talk uses the photo library to share images in meetings.",
        "NSPhotoLibraryAddUsageDescription": "Instant Talk saves meeting-related images to your photo library.",
        "UIBackgroundModes": ["audio", "voip", "remote-notification"],
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserTrackingUsageDescription": "Instant Talk does not track you. This permission is not used.",
        "CFBundleLocalizations": ["en", "fr", "es", "de", "it", "pt", "ja", "zh-Hans", "ar", "ko", "hi", "sw", "ru", "nl", "pl", "tr", "id", "vi", "th", "cs", "da", "fi", "hu", "nb", "ro", "uk"]
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#04070f"
      },
      "package": "com.instanttalk.app",
      "versionCode": 1,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "minSdkVersion": 24,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CHANGE_NETWORK_STATE",
        "android.permission.WAKE_LOCK",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Instant Talk uses the camera for video in multilingual meetings.",
          "microphonePermission": "Instant Talk uses the microphone for real-time voice translation and meeting audio.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Instant Talk uses the microphone for real-time voice translation and meeting audio."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#635bff",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": { "projectId": "YOUR_EAS_PROJECT_ID" },
      "apiUrl": "https://instant-talk.com"
    }
  }
}
