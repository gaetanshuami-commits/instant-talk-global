"use client";

import {
  Room,
  RoomEvent,
  Track,
  createLocalAudioTrack,
  createLocalVideoTrack,
  type LocalAudioTrack,
  type LocalVideoTrack,
  type RemoteParticipant,
  type RemoteTrack,
  type RemoteTrackPublication,
} from "livekit-client";
import { useEffect, useMemo, useRef, useState } from "react";
import { useParams } from "next/navigation";
import RealtimeVoiceOverlay from "@/components/RealtimeVoiceOverlay";

function getGridColumns(count: number) {
  if (count <= 1) return "1fr";
  if (count === 2) return "repeat(2, minmax(0, 1fr))";
  if (count <= 4) return "repeat(2, minmax(0, 1fr))";
  if (count <= 9) return "repeat(3, minmax(0, 1fr))";
  return "repeat(4, minmax(0, 1fr))";
}

function createRemoteTile(label: string, id: string) {
  const tile = document.createElement("div");
  tile.id = id;
  tile.style.position = "relative";
  tile.style.width = "100%";
  tile.style.aspectRatio = "16 / 9";
  tile.style.borderRadius = "20px";
  tile.style.overflow = "hidden";
  tile.style.background = "#111827";
  tile.style.border = "1px solid rgba(255,255,255,0.08)";
  tile.style.boxShadow = "0 10px 30px rgba(0,0,0,0.25)";

  const badge = document.createElement("div");
  badge.textContent = label;
  badge.style.position = "absolute";
  badge.style.left = "12px";
  badge.style.bottom = "12px";
  badge.style.padding = "6px 10px";
  badge.style.borderRadius = "999px";
  badge.style.fontSize = "12px";
  badge.style.fontWeight = "600";
  badge.style.background = "rgba(2,6,23,0.72)";
  badge.style.color = "#ffffff";
  badge.style.zIndex = "2";

  tile.appendChild(badge);
  return tile;
}

export default function RoomPage() {
  const params = useParams<{ roomId: string }>();
  const roomId = params.roomId;

  const room = useMemo(
    () =>
      new Room({
        adaptiveStream: true,
        dynacast: true,
      }),
    []
  );

  const localVideoWrapRef = useRef<HTMLDivElement | null>(null);
  const remoteGridRef = useRef<HTMLDivElement | null>(null);
  const localVideoTrackRef = useRef<LocalVideoTrack | null>(null);
  const localAudioTrackRef = useRef<LocalAudioTrack | null>(null);

  const [connected, setConnected] = useState(false);
  const [cameraEnabled, setCameraEnabled] = useState(true);
  const [micEnabled, setMicEnabled] = useState(true);
  const [cameraInfo, setCameraInfo] = useState("Initialisation caméra...");
  const [remoteCount, setRemoteCount] = useState(0);

  useEffect(() => {
    let mounted = true;

    function refreshRemoteCount() {
      if (!remoteGridRef.current) return;
      const count = remoteGridRef.current.querySelectorAll('[data-remote-tile="1"]').length;
      setRemoteCount(count);
    }

    function attachRemoteVideo(
      track: RemoteTrack,
      publication: RemoteTrackPublication,
      participant: RemoteParticipant
    ) {
      if (track.kind !== Track.Kind.Video) return;
      if (!remoteGridRef.current) return;

      const tileId = `remote-video-${participant.sid}-${publication.trackSid}`;
      if (document.getElementById(tileId)) return;

      const tile = createRemoteTile(participant.identity || "Participant", tileId);
      tile.setAttribute("data-remote-tile", "1");

      const videoEl = track.attach();
      videoEl.autoplay = true;
      videoEl.playsInline = true;
      videoEl.style.width = "100%";
      videoEl.style.height = "100%";
      videoEl.style.display = "block";
      videoEl.style.objectFit = "contain";
      videoEl.style.transform = "none";

      tile.appendChild(videoEl);
      remoteGridRef.current.appendChild(tile);
      refreshRemoteCount();
    }

    function attachRemoteAudio(
      track: RemoteTrack,
      publication: RemoteTrackPublication,
      participant: RemoteParticipant
    ) {
      if (track.kind !== Track.Kind.Audio) return;
      if (!remoteGridRef.current) return;

      const audioId = `remote-audio-${participant.sid}-${publication.trackSid}`;
      if (document.getElementById(audioId)) return;

      const audioEl = track.attach() as HTMLAudioElement;
      audioEl.id = audioId;
      audioEl.autoplay = true;
      audioEl.playsInline = true;
      audioEl.style.display = "none";

      remoteGridRef.current.appendChild(audioEl);
    }

    function detachRemote(publication?: RemoteTrackPublication) {
      if (!publication) return;

      const suffix = `-${publication.trackSid}`;
      document.querySelectorAll(`[id$="${suffix}"]`).forEach((node) => {
        try {
          node.querySelectorAll("video, audio").forEach((mediaNode) => {
            const media = mediaNode as HTMLMediaElement;
            media.pause?.();
            media.removeAttribute("src");
            media.load?.();
          });
        } catch {}
        node.remove();
      });

      refreshRemoteCount();
    }

    async function startRoom() {
      const tokenRes = await fetch("/api/livekit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          roomName: roomId,
          userId: "user-" + Math.random().toString(36).slice(2, 10),
        }),
      });

      const tokenData = await tokenRes.json();

      await room.connect(
        process.env.NEXT_PUBLIC_LIVEKIT_URL!,
        tokenData.token
      );

      const videoTrack = await createLocalVideoTrack({
        facingMode: "user",
        resolution: {
          width: 1920,
          height: 1080,
          frameRate: 30,
        },
      });

      try {
        await videoTrack.mediaStreamTrack.applyConstraints({
          width: { ideal: 1920, min: 1280 },
          height: { ideal: 1080, min: 720 },
          frameRate: { ideal: 30, min: 24, max: 30 },
          facingMode: "user",
        });
      } catch {}

      if ("contentHint" in videoTrack.mediaStreamTrack) {
        videoTrack.mediaStreamTrack.contentHint = "detail";
      }

      const audioTrack = await createLocalAudioTrack({
        echoCancellation: true,
        noiseSuppression: true,
        autoGainControl: true,
      });

      await room.localParticipant.publishTrack(videoTrack, {
        videoEncoding: {
          maxBitrate: 4500000,
          maxFramerate: 30,
        },
      });

      await room.localParticipant.publishTrack(audioTrack);

      localVideoTrackRef.current = videoTrack;
      localAudioTrackRef.current = audioTrack;

      const settings = videoTrack.mediaStreamTrack.getSettings();
      setCameraInfo(`${settings.width || 0}x${settings.height || 0} · ${settings.frameRate || 0} fps`);

      if (localVideoWrapRef.current) {
        const localEl = videoTrack.attach();
        localEl.autoplay = true;
        localEl.playsInline = true;
        localEl.style.width = "100%";
        localEl.style.height = "100%";
        localEl.style.display = "block";
        localEl.style.objectFit = "contain";
        localEl.style.transform = "scaleX(-1)";
        localVideoWrapRef.current.innerHTML = "";
        localVideoWrapRef.current.appendChild(localEl);
      }

      room.remoteParticipants.forEach((participant) => {
        participant.videoTrackPublications.forEach((publication) => {
          if (!publication.track) return;
          if (publication.track.kind === Track.Kind.Video) {
            attachRemoteVideo(publication.track, publication, participant);
          }
          if (publication.track.kind === Track.Kind.Audio) {
            attachRemoteAudio(publication.track, publication, participant);
          }
        });
      });

      room.on(
        RoomEvent.TrackSubscribed,
        (track: RemoteTrack, publication: RemoteTrackPublication, participant: RemoteParticipant) => {
          if (track.kind === Track.Kind.Video) attachRemoteVideo(track, publication, participant);
          if (track.kind === Track.Kind.Audio) attachRemoteAudio(track, publication, participant);
        }
      );

      room.on(RoomEvent.TrackUnsubscribed, (_track, publication) => {
        detachRemote(publication);
      });

      room.on(RoomEvent.ParticipantDisconnected, (participant: RemoteParticipant) => {
        participant.videoTrackPublications.forEach((publication) => {
          detachRemote(publication as RemoteTrackPublication);
        });
      });

      if (mounted) {
        setConnected(true);
        setCameraEnabled(true);
        setMicEnabled(true);
        refreshRemoteCount();
      }
    }

    startRoom();

    async function toggleCamera() {
    const track = localVideoTrackRef.current;
    if (!track) return;

    if (track.isMuted) {
      await track.unmute();
      setCameraEnabled(true);
      return;
    }

    await track.mute();
    setCameraEnabled(false);
  }

  async function toggleMic() {
    const track = localAudioTrackRef.current;
    if (!track) return;

    if (track.isMuted) {
      await track.unmute();
      setMicEnabled(true);
      return;
    }

    await track.mute();
    setMicEnabled(false);
  }

  function leaveRoom() {
    try {
      room.disconnect();
    } catch {}
    window.location.href = "/dashboard";
  }

  return () => {
      mounted = false;
      room.removeAllListeners();

      try {
        localVideoTrackRef.current?.stop();
      } catch {}

      try {
        localAudioTrackRef.current?.stop();
      } catch {}

      localVideoTrackRef.current = null;
      localAudioTrackRef.current = null;

      room.disconnect();
    };
  }, [room, roomId]);

    async function toggleCamera() {
    const track = localVideoTrackRef.current;
    if (!track) return;

    if (track.isMuted) {
      await track.unmute();
      setCameraEnabled(true);
      return;
    }

    await track.mute();
    setCameraEnabled(false);
  }

  async function toggleMic() {
    const track = localAudioTrackRef.current;
    if (!track) return;

    if (track.isMuted) {
      await track.unmute();
      setMicEnabled(true);
      return;
    }

    await track.mute();
    setMicEnabled(false);
  }

  function leaveRoom() {
    try {
      room.disconnect();
    } catch {}
    window.location.href = "/dashboard";
  }

  return (
    <div
      style={{
        width: "100vw",
        height: "100vh",
        background: "#020617",
        display: "flex",
        flexDirection: "column",
        color: "white",
      }}
    >
      <div
        style={{
          flex: 1,
          display: "grid",
          gridTemplateColumns: getGridColumns(remoteCount + 1),
          gap: "16px",
          padding: "16px",
          overflow: "auto",
        }}
      >
        <div
          style={{
            position: "relative",
            width: "100%",
            aspectRatio: "16 / 9",
            borderRadius: "20px",
            overflow: "hidden",
            background: "#111827",
            border: "1px solid rgba(255,255,255,0.08)",
            boxShadow: "0 10px 30px rgba(0,0,0,0.25)",
          }}
        >
          <div
            ref={localVideoWrapRef}
            style={{
              width: "100%",
              height: "100%",
            }}
          />
        </div>

        <div
          ref={remoteGridRef}
          style={{
            display: "contents",
          }}
        />
      </div>

      <div
        style={{
          height: "96px",
          background: "#0f172a",
          borderTop: "1px solid rgba(255,255,255,0.08)",
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
          gap: "14px",
          padding: "0 16px",
        }}
      >
        <button
          onClick={toggleMic}
          style={{
            minWidth: "150px",
            height: "48px",
            borderRadius: "14px",
            border: "1px solid rgba(255,255,255,0.12)",
            background: micEnabled ? "#1f2937" : "#7f1d1d",
            color: "white",
            fontWeight: 700,
            cursor: "pointer",
          }}
        >
          {micEnabled ? "Micro activé" : "Micro coupé"}
        </button>

        <button
          onClick={toggleCamera}
          style={{
            minWidth: "170px",
            height: "48px",
            borderRadius: "14px",
            border: "1px solid rgba(255,255,255,0.12)",
            background: cameraEnabled ? "#1f2937" : "#7f1d1d",
            color: "white",
            fontWeight: 700,
            cursor: "pointer",
          }}
        >
          {cameraEnabled ? "Caméra activée" : "Caméra coupée"}
        </button>

        <button
          onClick={leaveRoom}
          style={{
            minWidth: "140px",
            height: "48px",
            borderRadius: "14px",
            border: "1px solid rgba(239,68,68,0.35)",
            background: "#7f1d1d",
            color: "white",
            fontWeight: 700,
            cursor: "pointer",
          }}
        >
          Quitter
        </button>
      </div>

      <RealtimeVoiceOverlay room={room} muteOriginalMic={async () => { await localAudioTrackRef.current?.mute(); setMicEnabled(false); }} unmuteOriginalMic={async () => { await localAudioTrackRef.current?.unmute(); setMicEnabled(true); }} />
    </div>
  );
}



