"use client";

import { useEffect, useRef, useState } from "react";
import { type Room } from "livekit-client";
import { VoiceQueue } from "@/lib/realtime/voice-queue";

type Props = {
  room: Room;
  muteOriginalMic: () => Promise<void>;
  unmuteOriginalMic: () => Promise<void>;
};

const LANGUAGE_OPTIONS = [
  { value: "FR", label: "Français" },
  { value: "EN", label: "English" },
  { value: "ES", label: "Español" },
  { value: "DE", label: "Deutsch" },
  { value: "ZH", label: "Mandarin / 中文" },
  { value: "AR", label: "العربية" },
  { value: "HI", label: "हिन्दी" },
  { value: "PT", label: "Português" },
  { value: "RU", label: "Русский" },
  { value: "JA", label: "日本語" },
  { value: "BN", label: "বাংলা" },
  { value: "IT", label: "Italiano" },
  { value: "NL", label: "Nederlands" },
  { value: "LB", label: "Lëtzebuergesch" },
  { value: "EL", label: "Ελληνικά" },
  { value: "SV", label: "Svenska" },
  { value: "NO", label: "Norsk" },
  { value: "DA", label: "Dansk" },
  { value: "FI", label: "Suomi" },
  { value: "IS", label: "Íslenska" },
  { value: "PL", label: "Polski" },
  { value: "UK", label: "Українська" },
  { value: "CS", label: "Čeština" },
  { value: "SK", label: "Slovenčina" },
  { value: "HU", label: "Magyar" },
  { value: "RO", label: "Română" },
  { value: "BG", label: "Български" },
  { value: "KO", label: "한국어" },
  { value: "TR", label: "Türkçe" },
  { value: "HE", label: "עברית" },
  { value: "LN", label: "Lingála" },
  { value: "SW", label: "Kiswahili" }
];

const VOICE_BY_LANG: Record<string, string | undefined> = {
  FR: "fr-FR-DeniseNeural",
  EN: "en-US-JennyNeural",
  ES: "es-ES-ElviraNeural",
  DE: "de-DE-KatjaNeural",
  ZH: "zh-CN-XiaoxiaoNeural",
  AR: "ar-SA-ZariyahNeural",
  HI: "hi-IN-SwaraNeural",
  PT: "pt-BR-FranciscaNeural",
  RU: "ru-RU-SvetlanaNeural",
  JA: "ja-JP-NanamiNeural",
  IT: "it-IT-ElsaNeural",
  NL: "nl-NL-ColetteNeural",
  EL: "el-GR-AthinaNeural",
  SV: "sv-SE-SofieNeural",
  NO: "nb-NO-PernilleNeural",
  DA: "da-DK-ChristelNeural",
  FI: "fi-FI-NooraNeural",
  PL: "pl-PL-ZofiaNeural",
  UK: "uk-UA-PolinaNeural",
  CS: "cs-CZ-VlastaNeural",
  SK: "sk-SK-ViktoriaNeural",
  HU: "hu-HU-NoemiNeural",
  RO: "ro-RO-AlinaNeural",
  BG: "bg-BG-KalinaNeural",
  KO: "ko-KR-SunHiNeural",
  TR: "tr-TR-EmelNeural",
  HE: "he-IL-HilaNeural",
  SW: "sw-KE-ZuriNeural"
};

export default function RealtimeVoiceOverlay({
  room,
  muteOriginalMic,
  unmuteOriginalMic,
}: Props) {
  const [active, setActive] = useState(false);
  const [targetLang, setTargetLang] = useState("EN");
  const [status, setStatus] = useState("Prêt");
  const [heardText, setHeardText] = useState("");
  const [translatedText, setTranslatedText] = useState("");

  const mediaRecorderRef = useRef<MediaRecorder | null>(null);
  const wsRef = useRef<WebSocket | null>(null);
  const streamRef = useRef<MediaStream | null>(null);
  const voiceQueueRef = useRef<VoiceQueue | null>(null);

  useEffect(() => {
    voiceQueueRef.current = new VoiceQueue({
      room,
      defaultLang: targetLang,
      defaultVoice: VOICE_BY_LANG[targetLang],
      onStart: () => setStatus("Lecture vocale…"),
      onEnd: () => setStatus(active ? "Micro traducteur ouvert" : "Prêt"),
      onError: (error) => {
        console.error("[voice-overlay] voice queue error:", error);
        setStatus("Erreur audio");
      },
    });

    return () => {
      voiceQueueRef.current?.destroy();
    };
  }, [room, targetLang, active]);

  async function startTranslator() {
    if (active) return;

    try {
      setActive(true);
      setStatus("Ouverture…");
      setHeardText("");
      setTranslatedText("");

      await muteOriginalMic();

      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      streamRef.current = stream;

      const tokenRes = await fetch("/api/deepgram-token");
      const token = (await tokenRes.json()).token;

      const ws = new WebSocket(
        "wss://api.deepgram.com/v1/listen?model=nova-3&interim_results=true&smart_format=true&endpointing=300",
        ["token", token]
      );

      wsRef.current = ws;

      ws.onopen = () => {
        setStatus("Micro traducteur ouvert");

        let mimeType = "audio/webm;codecs=opus";
        if (!MediaRecorder.isTypeSupported(mimeType)) {
          mimeType = "audio/webm";
        }

        const recorder = new MediaRecorder(stream, { mimeType });
        mediaRecorderRef.current = recorder;

        recorder.ondataavailable = async (e) => {
          if (e.data.size > 0 && ws.readyState === WebSocket.OPEN) {
            ws.send(e.data);
          }
        };

        recorder.start(250);
      };

      ws.onmessage = async (event) => {
        const json = JSON.parse(event.data);
        const text = String(json.channel?.alternatives?.[0]?.transcript ?? "").trim();

        if (!text) return;

        setHeardText(text);

        if (!json.is_final) return;

        setStatus("Traduction…");

        const translate = await fetch("/api/translate", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            text,
            targetLang,
          }),
        });

        const result = await translate.json();

        if (!result?.translatedText) {
          setStatus("Erreur traduction");
          return;
        }

        setTranslatedText(result.translatedText);

        voiceQueueRef.current?.enqueue({
          text: result.translatedText,
          lang: targetLang,
          voice: VOICE_BY_LANG[targetLang],
        });

        setStatus("Micro traducteur ouvert");
      };

      ws.onerror = () => {
        console.error("[voice-overlay] deepgram websocket error");
        setStatus("Erreur Deepgram");
      };

      ws.onclose = () => {
        try {
          mediaRecorderRef.current?.stop();
        } catch {}
      };
    } catch (error) {
      console.error("[voice-overlay] startTranslator failed:", error);
      setStatus("Erreur démarrage");
      setActive(false);

      try {
        await unmuteOriginalMic();
      } catch {}
    }
  }

  async function stopTranslator() {
    setActive(false);
    setStatus("Fermeture…");

    try {
      mediaRecorderRef.current?.stop();
    } catch {}

    try {
      wsRef.current?.close();
    } catch {}

    try {
      streamRef.current?.getTracks().forEach((track) => track.stop());
    } catch {}

    mediaRecorderRef.current = null;
    wsRef.current = null;
    streamRef.current = null;

    await unmuteOriginalMic();
    setStatus("Prêt");
  }

  async function toggleTranslator() {
    if (!active) {
      await startTranslator();
      return;
    }

    await stopTranslator();
  }

  return (
    <div className="absolute bottom-6 right-6 z-[9999]">
      <div className="w-[300px] rounded-2xl border border-white/10 bg-black/85 p-3 text-white shadow-xl backdrop-blur">
        <div className="mb-2 flex items-center justify-between gap-2">
          <span className="text-[11px] uppercase tracking-[0.18em] text-white/55">
            Translation
          </span>
          <span className="text-[11px] text-white/60">{status}</span>
        </div>

        <select
          value={targetLang}
          onChange={(e) => setTargetLang(e.target.value)}
          className="mb-2 w-full rounded-lg border border-white/10 bg-black px-3 py-2 text-xs text-white outline-none"
          style={{ backgroundColor: "#020617", color: "#ffffff" }}
        >
          {LANGUAGE_OPTIONS.map((language) => (
            <option
              key={language.value}
              value={language.value}
              style={{ backgroundColor: "#020617", color: "#ffffff" }}
            >
              {language.label}
            </option>
          ))}
        </select>

        <div className="mb-2 min-h-[58px] rounded-xl border border-white/8 bg-white/5 px-3 py-2 text-xs text-white/80">
          <div className="mb-1 text-[10px] uppercase tracking-[0.15em] text-white/40">
            Entendu
          </div>
          <div>{heardText || "…"}</div>
        </div>

        <div className="mb-3 min-h-[58px] rounded-xl border border-white/8 bg-white/5 px-3 py-2 text-xs text-white/90">
          <div className="mb-1 text-[10px] uppercase tracking-[0.15em] text-white/40">
            Traduit
          </div>
          <div>{translatedText || "…"}</div>
        </div>

        <button
          onClick={toggleTranslator}
          className={`w-full rounded-xl px-5 py-3 text-sm font-semibold text-white shadow-lg transition active:scale-[0.98] ${
            active ? "bg-red-600 hover:bg-red-500" : "bg-indigo-600 hover:bg-indigo-500"
          }`}
        >
          {active ? "Fermer le micro traducteur" : "Ouvrir le micro traducteur"}
        </button>
      </div>
    </div>
  );
}
