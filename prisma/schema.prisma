generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subscription {
  id                   String    @id @default(cuid())
  stripeCustomerId     String    @unique
  stripeSubscriptionId String    @unique
  plan                 String
  status               String
  customerEmail        String?
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  enterpriseEnabled    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([plan])
  @@index([status])
}

// Tracks active participants per room channel.
// Upserted at token generation; expires naturally (joinedAt > 2h = inactive).
model RoomSlot {
  id          String   @id @default(cuid())
  channelName String
  customerRef String
  uid         Int
  plan        String
  joinedAt    DateTime @default(now())

  @@unique([channelName, customerRef])
  @@index([channelName])
  @@index([joinedAt])
}

model Meeting {
  id          String            @id @default(cuid())
  title       String
  description String?
  hostEmail   String
  roomId      String            @unique
  inviteToken String            @unique
  startsAt    DateTime
  endsAt      DateTime
  timezone    String            @default("Europe/Paris")
  status      MeetingStatus     @default(SCHEDULED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  invitees    MeetingInvite[]
  reminders   MeetingReminder[]

  @@index([startsAt])
  @@index([endsAt])
  @@index([status])
}

model MeetingInvite {
  id        String       @id @default(cuid())
  meetingId String
  email     String
  name      String?
  status    InviteStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  meeting   Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, email])
  @@index([email])
}

model MeetingReminder {
  id        String          @id @default(cuid())
  meetingId String
  remindAt  DateTime
  sentAt    DateTime?
  channel   ReminderChannel @default(EMAIL)
  createdAt DateTime        @default(now())
  meeting   Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([remindAt])
  @@index([sentAt])
}

enum MeetingStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum InviteStatus {
  PENDING
  SENT
  ACCEPTED
  DECLINED
}

enum ReminderChannel {
  EMAIL
}
