generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Subscription {
  id                   String    @id @default(cuid())
  stripeCustomerId     String    @unique
  stripeSubscriptionId String    @unique
  plan                 String
  status               String
  customerEmail        String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  trialEndsAt          DateTime?
  enterpriseEnabled    Boolean   @default(false)

  @@index([plan])
  @@index([status])
  @@index([customerEmail])
}

model RoomSlot {
  id          String   @id @default(cuid())
  channelName String
  customerRef String
  uid         Int
  plan        String
  joinedAt    DateTime @default(now())

  @@unique([channelName, customerRef])
  @@index([channelName])
  @@index([joinedAt])
}

model Meeting {
  id          String            @id @default(cuid())
  title       String
  description String?
  hostEmail   String
  roomId      String            @unique
  inviteToken String            @unique
  startsAt    DateTime
  endsAt      DateTime
  timezone    String            @default("Europe/Paris")
  status      MeetingStatus     @default(SCHEDULED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  invitees    MeetingInvite[]
  reminders   MeetingReminder[]

  @@index([startsAt])
  @@index([endsAt])
  @@index([status])
}

model MeetingInvite {
  id        String       @id @default(cuid())
  meetingId String
  email     String
  name      String?
  status    InviteStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  meeting   Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, email])
  @@index([email])
}

model MeetingReminder {
  id        String          @id @default(cuid())
  meetingId String
  remindAt  DateTime
  sentAt    DateTime?
  channel   ReminderChannel @default(EMAIL)
  createdAt DateTime        @default(now())
  meeting   Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([remindAt])
  @@index([sentAt])
}

model Contact {
  id          String   @id @default(cuid())
  customerRef String
  name        String
  email       String
  company     String?
  role        String?
  lang        String?
  color       String   @default("#6366f1")
  starred     Boolean  @default(false)
  online      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([customerRef, email])
  @@index([customerRef])
}

model ChatRoom {
  id          String        @id @default(cuid())
  customerRef String
  name        String
  emoji       String?
  color       String        @default("#6366f1")
  createdAt   DateTime      @default(now())
  messages    ChatMessage[]

  @@index([customerRef])
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  author    String
  text      String
  lang      String?
  mine      Boolean  @default(false)
  createdAt DateTime @default(now())
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([createdAt])
}

model Webinar {
  id           String        @id @default(cuid())
  customerRef  String
  title        String
  topic        String?
  host         String
  startsAt     DateTime
  durationMins Int           @default(60)
  maxAttendees Int           @default(1000)
  langs        String[]      @default([])
  color        String        @default("#6366f1")
  status       WebinarStatus @default(UPCOMING)
  roomId       String        @default("")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([customerRef])
  @@index([startsAt])
}

model UserSettings {
  id          String   @id @default(cuid())
  customerRef String   @unique
  data        Json     @default("{}")
  updatedAt   DateTime @updatedAt
}

enum MeetingStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum InviteStatus {
  PENDING
  SENT
  ACCEPTED
  DECLINED
}

enum ReminderChannel {
  EMAIL
}

enum WebinarStatus {
  UPCOMING
  LIVE
  ENDED
  CANCELLED
}
